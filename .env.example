# Copy to .env and fill in to enable the real Claude assistant.
# Without it, the agent falls back to a built-in playbook (demo still works).
ANTHROPIC_API_KEY=
AGENT_MODEL=claude-sonnet-4-6

# ThingsBoard Cloud — paste your device Access Token here to forward data to the cloud
TB_TOKEN=
TB_HOST=mqtt.thingsboard.cloud

# Telegram alarm bot (optional) — create a bot with @BotFather, then get your chat id
TG_BOT_TOKEN=
TG_CHAT_ID=
